# ─── LLM Backend ──────────────────────────────────────────────────────────────
# Choose your LLM backend: ollama (free, local) or claude (Anthropic API)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
# Local dev: http://localhost:11434
# From inside Docker: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Claude / Anthropic settings (used when LLM_BACKEND=claude)
# Get your key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Infrastructure ────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9091

# ─── Agent behaviour ───────────────────────────────────────────────────────────
# Approval mode: AUTO | DRY_RUN | MANUAL
# AUTO     — auto-approves safe actions, prompts human for restarts/scale-down
# DRY_RUN  — logs everything, executes nothing (safe for testing)
# MANUAL   — always prompts for human approval
APPROVAL_MODE=AUTO

NUM_WORKERS=2
LOG_LEVEL=INFO
DRY_RUN=false

# Mock Prometheus scenario (high_error_rate | high_latency | memory_leak | service_down | cpu_spike)
MOCK_SCENARIO=high_error_rate

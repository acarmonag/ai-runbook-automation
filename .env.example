# ─── LLM Backend ──────────────────────────────────────────────────────────────
# Choose: ollama (free, local GPU) or claude (Anthropic API, pay-per-token)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
# Local dev: http://localhost:11434
# From inside Docker: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Anthropic API settings (used when LLM_BACKEND=claude)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Infrastructure ────────────────────────────────────────────────────────────
# These are overridden inside Docker Compose to use service DNS names.
# Only set these when running agents outside of Docker (e.g. make simulate).
PROMETHEUS_URL=http://localhost:9091
DATABASE_URL=postgresql+asyncpg://sre:sre@localhost:5432/runbooks
REDIS_URL=redis://localhost:6379

# ─── Agent Behaviour ───────────────────────────────────────────────────────────
# AUTO     — all actions pre-approved, no human prompts (use for demos)
# MANUAL   — asks for approval before every destructive action
# DRY_RUN  — logs everything, executes nothing (safe for exploring)
APPROVAL_MODE=AUTO

NUM_WORKERS=2
LOG_LEVEL=INFO

# ─── Mock Scenario ─────────────────────────────────────────────────────────────
# Controls which fault the mock Prometheus simulates.
# Options: high_error_rate | high_latency | memory_leak | service_down | cpu_spike
MOCK_SCENARIO=high_error_rate

# Use mock log lines instead of real Docker container logs (recommended for demos)
USE_MOCK_LOGS=true

# ─── Alert Correlation ─────────────────────────────────────────────────────────
# How long (seconds) to merge identical alerts into one incident.
# Lowering this speeds up re-testing the same scenario.
CORRELATION_WINDOW_SECONDS=60

# ─── Optional Integrations ─────────────────────────────────────────────────────
# API_KEY=change-me-before-production
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# PAGERDUTY_ROUTING_KEY=your-key-here
